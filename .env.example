# Copy to .env and fill in. chmod 600.
DATABASE_URL=postgresql+asyncpg://openmarket:CHANGE_ME@db:5432/openmarket
DB_PASSWORD=CHANGE_ME

# Generate with: openssl rand -hex 32
SESSION_SECRET_KEY=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32

# Fiskaly (KassenSichV Cloud-TSE)
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_TSS_ID=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com

# Backups (fill before Plan 3 lands)
BACKUP_ENCRYPTION_KEY=

# Optional first-run bootstrap (remove after first successful /auth/setup)
FIRST_RUN_OWNER_EMAIL=
FIRST_RUN_OWNER_PASSWORD=

# Card terminal (ZVT-700 over LAN). Leave TERMINAL_HOST empty for mock.
TERMINAL_HOST=
TERMINAL_PORT=22000
TERMINAL_PASSWORD=000000

# Merchant identity — printed on receipts (§14 UStG)
MERCHANT_NAME=My Market GmbH
MERCHANT_ADDRESS=Musterstr. 1, 12345 Musterstadt
MERCHANT_TAX_ID=123/456/78901
MERCHANT_VAT_ID=DE123456789
MERCHANT_REGISTER_ID=KASSE-01

# ESC/POS receipt printer (USB). Defaults: Epson TM-m30III.
PRINTER_VENDOR_ID=0x04b8
PRINTER_PRODUCT_ID=0x0e28
PRINTER_PROFILE=TM-m30III

# Session cookie — must be true in prod (HTTPS)
SESSION_COOKIE_SECURE=true

# CORS allowed origins (admin.local, pos.local, store.local, or your domain)
ALLOWED_CORS_ORIGINS=https://admin.local,https://pos.local,https://store.local
